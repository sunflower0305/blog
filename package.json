{
  "name": "leyang-blog",
  "version": "0.1.0",
  "private": false,
  "description": "Open-source blog with Next.js 16, Cloudflare D1, R2, built-in themes, and AI provider presets.",
  "homepage": "https://github.com/sunflower0305/blog",
  "bugs": {
    "url": "https://github.com/sunflower0305/blog/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunflower0305/blog.git"
  },
  "type": "module",
  "scripts": {
    "dev": "CLOUDFLARE_VITE_FORCE_LOCAL=true vp exec vinext dev",
    "dev:remote": "bash scripts/cf-dev-remote-vinext.sh",
    "build": "vp exec vinext build",
    "check": "vp check",
    "test": "vp test",
    "test:run": "vp test run",
    "typecheck": "vp check --no-fmt --no-lint",
    "verify": "bash scripts/verify.sh full",
    "verify:quick": "bash scripts/verify.sh quick",
    "preview": "bash scripts/cf-preview-vinext.sh",
    "deploy": "bash scripts/cf-deploy-vinext.sh",
    "deploy:dry-run": "bash scripts/cf-deploy-vinext.sh --dry-run",
    "deploy:warm-cdn": "bash scripts/cf-deploy-vinext.sh --warm-cdn",
    "worktree:add": "bash scripts/worktree-add.sh",
    "worktree:prune": "git worktree prune",
    "cf-typegen": "bash scripts/cf-typegen.sh",
    "cf:init": "bash scripts/cf-init.sh",
    "config:generate": "node scripts/runtime-env-config.mjs generate-env-example",
    "config:check": "node scripts/runtime-env-config.mjs validate",
    "start": "vp exec vinext start",
    "lint": "vp check --no-fmt --no-error-on-unmatched-pattern -- --ignore-pattern 'dist/**' --ignore-pattern '.wrangler/**' --ignore-pattern 'worker-configuration.d.ts'"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.4",
    "@tiptap/extension-character-count": "^3.27.4",
    "@tiptap/extension-code-block-lowlight": "^3.27.4",
    "@tiptap/extension-color": "^3.27.4",
    "@tiptap/extension-highlight": "^3.27.4",
    "@tiptap/extension-image": "^3.27.4",
    "@tiptap/extension-table": "^3.27.4",
    "@tiptap/extension-task-item": "^3.27.4",
    "@tiptap/extension-task-list": "^3.27.4",
    "@tiptap/extension-text-style": "^3.27.4",
    "@tiptap/extension-youtube": "^3.27.4",
    "@tiptap/pm": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "@tiptap/suggestion": "^3.27.4",
    "@vinext/cloudflare": "1.0.0-beta.1",
    "cmdk": "^1.1.1",
    "highlight.js": "^11.11.1",
    "html2pdf.js": "^0.14.0",
    "juice": "^12.1.1",
    "katex": "^0.17.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.24.0",
    "markdown-it": "^14.3.0",
    "nanoid": "^6.0.0",
    "next": "16.2.10",
    "openai": "^6.47.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-easy-crop": "^6.2.2",
    "rehype": "^13.0.2",
    "rehype-highlight": "^7.0.2",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "tippy.js": "^6.3.7",
    "tiptap-extension-auto-joiner": "^0.1.3",
    "tiptap-extension-global-drag-handle": "^0.1.18",
    "tiptap-markdown": "^0.9.0",
    "turndown": "^7.2.4",
    "vinext": "1.0.0-beta.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.27",
    "happy-dom": "^20.10.6",
    "react-server-dom-webpack": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plus": "0.2.4",
    "vitest": "4.1.10",
    "wrangler": "^4.110.0"
  },
  "packageManager": "pnpm@11.10.0",
  "cloudflare": {
    "bindings": {
      "NEXT_PUBLIC_SITE_URL": {
        "description": "你的博客公网域名，例如 `https://blog.example.com`。"
      },
      "ADMIN_PASSWORD": {
        "description": "后台 `/admin` 登录密码。请使用高强度独立密码。"
      },
      "ADMIN_TOKEN_SALT": {
        "description": "管理员 Token 签名盐。可用 `openssl rand -hex 32` 生成。"
      },
      "AI_CONFIG_ENCRYPTION_SECRET": {
        "description": "用于加密保存 AI 供应商 Key。可用 `openssl rand -hex 32` 生成。"
      },
      "AI_API_KEY": {
        "description": "可选。外部 AI 服务的 API Key，用于文本生成或生图能力。"
      }
    }
  }
}
